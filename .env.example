`   # Environment Variables for Task Manager API
# Copy this file as .env and fill in your values

# Database (AWS RDS PostgreSQL)
DB_URL=jdbc:postgresql://your-rds-endpoint.amazonaws.com:5432/taskmanager
DB_USER=postgres
DB_PASSWORD=your_rds_password_here

# JWT
JWT_SECRET=your_super_secret_key_here_make_it_long_and_random

# Redis Cache (Local or Remote)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_SSL=false
# AWS S3 (optional — needed for file upload)
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
AWS_BUCKET_NAME=task-manager-uploads
AWS_REGION=ap-south-1

# Server
PORT=8080

# Gemini AI (get free key from https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Frontend URL (for CORS in production)
FRONTEND_URL=http://localhost:5173
